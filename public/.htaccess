# IGO Agri Mart — SPA routing for Hostinger (Apache)
# Serves index.html for all routes (e.g. /admin) so the React app handles them.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# Cache static assets aggressively, never cache index.html
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|webp|png|jpg|jpeg|svg|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
